<form action="/books/upsert" role="form" method="post">
<input type="hidden" name="_csrf" value="{{_csrfToken}}">
  <h1>{{book.title}}</h1>
{{#if book.authors}}
<p>Written by {{#each book.authors}}{{this.firstName}} {{this.lastName}}{{#unless @last}}, {{/unless}}{{/each}}
</p>
{{/if}}
<p>
  Originally published in {{book.publishingYear}}
</p>
{{#if genres}}   {{!//if the book has a specific genre id attached to it then that genre id will be listed in the details page--}}
<p>
  Genre: {{#each genre.name}}{{this.genreName}}{{#unless @last}}, {{/unless}}{{/each}}  
</p>
{{/if}}
</form>
{{#if currentUser}}
<div>
  <form action="/books_users/upsert" role="form" method="post">
    <input type="hidden" name="_csrf" value="{{_csrfToken}}">
    <input type="hidden" name="bookId" value="{{bookId}}">
    <input type="hidden" name="userId" value="{{currentUser.id}}">
    {{#if bookUser}}
      <input type="hidden" name="id" value="{{bookUser.id}}">
    {{/if}}
    <label for="status">Status</label>
    <select name="status" id="status">
      {{#unless (and bookUser bookUser.readStatus)}}
        <option disabled value selected>-- select status --</option>
      {{/unless}}
      {{#each statuses}}
        <option value="{{this}}" {{#if (and @root.bookUser (eq @root.bookUser.readStatus this))}}selected{{/if}}>{{this}}</option>
      {{/each}}
    </select>
    <button type="submit">Submit</button>
  </form>
</div>
{{/if}}
<div>
  <h1>Comments</h1>
      {{!-- <form action="/comments/upsert" role="form" method="post">     --}}
    <input type="hidden" name="_csrf" value="plsKg8bG-YTnDOioEiiezbsuGhtSaXeBfdRI">
    <div>
        <h1>BookedIn || Comments Form</h1>
        <label for="comment_text">Comment</label>
        <input type="text" id="comment_text" name="text" > 
    </div>
    <button type="submit" class="btn btn-primary">Submit</button>
    {{!-- </form> --}}
  {{#if comments}}
    <p>{{#each comments}}{{this.text}} By {{this.userEmail}}<br>{{#if userEmail}}<a href="/comments/edit?id={{@index}}">Edit</a>{{/if}}<br>{{/each}}
    </p>
  {{/if}}
</div>